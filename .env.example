# Server-only OpenAI key. Do not prefix with NEXT_PUBLIC.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Optional DART disclosure integration.
OPEN_DART_API_KEY=

# Optional news integration. If unset, the app uses mock news.
NEWS_API_KEY=
NEWS_API_URL=

# Optional Korean stock quote/chart integration.
STOCK_API_BASE_URL=
STOCK_API_KEY=
